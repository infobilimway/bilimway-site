---
---

<section id="contact" class="contact-band">
  <div class="contact-band__stripe"></div>

  <div class="contact-band__container">
    <div class="contact-band__card">
      <div class="contact-band__info">
        <h2 class="contact-band__title">
          Свяжитесь с нами
        </h2>
        <p class="contact-band__subtitle">
          Задайте вопрос или запишитесь на бесплатную консультацию по поступлению в Беларусь.
        </p>

        <ul class="contact-band__list">
          <li>
            <div class="contact-band__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <a href="tel:+375259178241">+375 (25) 917-82-41</a>
          </li>

          <li>
            <div class="contact-band__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <a href="mailto:info.bilimway@gmail.com">info.bilimway@gmail.com</a>
          </li>
        </ul>

        <div class="contact-band__socials">
          <a href="https://t.me/bilimway_study" target="_blank" rel="noopener noreferrer" aria-label="Telegram" class="social-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </a>

          <a href="https://instagram.com/bilimway.study" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>

          <a href="https://www.tiktok.com/@bilimway.studyy" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="social-btn">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.24V2h-3.12v13.18a2.67 2.67 0 1 1-2.67-2.67c.23 0 .45.03.67.08V9.43a5.8 5.8 0 0 0-.67-.04A5.79 5.79 0 1 0 15.82 15V8.33a7.9 7.9 0 0 0 4.61 1.48V6.69h-.84z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="contact-band__form-wrap">
        <form class="contact-band__form" id="contact-preview-form">
          <div class="contact-band__field">
            <input type="text" name="name" placeholder="Введите ваше имя" required />
          </div>
          <div class="contact-band__field">
            <input type="tel" name="phone" placeholder="Номер телефона" required />
          </div>
          <div class="contact-band__field contact-band__field--full">
            <textarea name="message" rows="4" placeholder="Ваше сообщение (необязательно)"></textarea>
          </div>

          <div class="contact-band__actions">
            <button type="submit" class="btn btn-primary">
              Отправить заявку
            </button>
            <p class="contact-band__status" id="contact-preview-status"></p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const form = document.getElementById('contact-preview-form');
    if (!form) return;

    const statusEl = document.getElementById('contact-preview-status');

    form.addEventListener('submit', function (event) {
      event.preventDefault();

      const formData = new FormData(form);
      const name = formData.get('name') || '';
      const phone = formData.get('phone') || '';
      const message = formData.get('message') || '';

      // Если есть глобальная функция открытия модалки (из LeadModal.astro) – используем её
      if (window.openLeadModal) {
        window.openLeadModal('');

        // Дадим модалке чуть времени открыться и вставим данные
        setTimeout(function () {
          const modal = document.getElementById('lead-modal');
          if (!modal) return;

          const modalName = modal.querySelector('input[name="name"]');
          const modalPhone = modal.querySelector('input[name="phone"]');
          const modalComment = modal.querySelector('textarea[name="comment"]');

          if (modalName && name) modalName.value = String(name);
          if (modalPhone && phone) modalPhone.value = String(phone);
          if (modalComment && message) modalComment.value = String(message);
        }, 100);

        form.reset();
        if (statusEl) {
          statusEl.textContent = 'Форма открыта. Завершите заявку в окне.';
        }
        return;
      }

      // Fallback: если по какой-то причине LeadModal не подключён,
      // отправляем напрямую в /api/leads (минимальный сценарий)
      (async () => {
        if (statusEl) statusEl.textContent = 'Отправка...';

        const payload = {
          name,
          citizenship: '',
          email: '',
          phone,
          comment: message,
          sourcePage: window.location.pathname
        };

        try {
          const response = await fetch('/api/leads', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          const text = await response.text();
          const data = text ? JSON.parse(text) : { ok: false };

          if (response.ok && data.ok) {
            if (statusEl) statusEl.textContent = 'Заявка отправлена';
            form.reset();
          } else {
            if (statusEl) statusEl.textContent = data.message || 'Ошибка отправки';
          }
        } catch (err) {
          if (statusEl) statusEl.textContent = 'Ошибка сети, попробуйте ещё раз';
        }
      })();
    });
  })();
</script>