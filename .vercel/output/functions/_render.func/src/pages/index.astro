---
import BaseLayout from '../layouts/BaseLayout.astro'; 
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import BenefitsSection from '../components/BenefitsSection.astro';
import UniversitySection from '../components/UniversitySection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import AboutPreviewSection from '../components/AboutPreviewSection.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import FaqSection from '../components/FaqSection.astro';
import PostsSection from '../components/PostsSection.astro';
import ContactPreviewSection from '../components/ContactPreviewSection.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
import LeadModal from '../components/LeadModal.astro';

import { sanityClient } from 'sanity:client';

import { universitiesQuery } from '../sanity/queries/universities';
import { servicesQuery } from '../sanity/queries/services';
import { latestPostsQuery } from '../sanity/queries/posts';
import { approvedReviewsQuery } from '../sanity/queries/reviews';

const universities = await sanityClient.fetch(universitiesQuery);
const services = await sanityClient.fetch(servicesQuery);
const posts = await sanityClient.fetch(latestPostsQuery);
const approvedReviews = await sanityClient.fetch(approvedReviewsQuery);
---

<BaseLayout
  title="BilimWay International — Поступление в университеты Беларуси"
  description="BilimWay помогает иностранным абитуриентам поступать в университеты Беларуси: подбор вуза, документы, сопровождение и поддержка."
>
  <Header />

  <main class="site-main">
    <HeroSection />
    <BenefitsSection />
    <UniversitySection universities={universities} />
    <ServicesSection services={services} />
    <ProcessSection />
    <AboutPreviewSection />
    <ReviewsSection approvedReviews={approvedReviews} />
    <FaqSection />
    <PostsSection posts={posts} />
    <ContactPreviewSection />
    <CtaSection />
  </main>

  <Footer />
  <LeadModal />

  <script>
    document.documentElement.classList.add('js');

    const revealItems = document.querySelectorAll('.reveal');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.15 }
    );

    revealItems.forEach((item) => observer.observe(item));
  </script>
</BaseLayout>